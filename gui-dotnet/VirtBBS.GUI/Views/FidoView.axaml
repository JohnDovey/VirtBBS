<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VirtBBS.GUI.ViewModels"
             x:Class="VirtBBS.GUI.Views.FidoView"
             x:DataType="vm:FidoViewModel">

    <DockPanel Margin="10">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,10">
            <TextBlock Text="Network:" VerticalAlignment="Center"/>
            <ComboBox ItemsSource="{Binding NetworkNames}" SelectedItem="{Binding SelectedNetwork}" Width="180"/>
            <Button Content="Reload Networks" Command="{Binding LoadNetworksCommand}"/>
        </StackPanel>

        <TabControl>
            <TabItem Header="Mail Ops">
                <StackPanel Spacing="8" MaxWidth="520" Margin="8">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Button Content="Toss Inbound" Command="{Binding TossCommand}"/>
                        <Button Content="Scan Outbound" Command="{Binding ScanCommand}"/>
                        <Button Content="Poll Uplink" Command="{Binding PollCommand}"/>
                    </StackPanel>
                    <TextBlock Text="Nodelist Import" FontWeight="Bold"/>
                    <TextBox Text="{Binding ImportPath}" PlaceholderText="/path/to/NODELIST.170"/>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Button Content="Import File" Command="{Binding ImportNodelistCommand}"/>
                        <Button Content="Fetch from URL" Command="{Binding FetchNodelistCommand}"/>
                        <Button Content="Check Version" Command="{Binding CheckVersionCommand}"/>
                    </StackPanel>
                    <TextBlock Text="{Binding VersionText}" Opacity="0.8"/>
                </StackPanel>
            </TabItem>

            <TabItem Header="Nodelist">
                <DockPanel Margin="8">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="6" Margin="0,0,0,8">
                        <TextBox Text="{Binding NodeQuery}" Width="220" PlaceholderText="address or name"/>
                        <Button Content="Search" Command="{Binding SearchNodesCommand}"/>
                        <Button Content="◀" Command="{Binding PrevPageCommand}"/>
                        <TextBlock Text="{Binding NodePage}" VerticalAlignment="Center"/>
                        <TextBlock Text="/" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding NodeTotalPages}" VerticalAlignment="Center"/>
                        <Button Content="▶" Command="{Binding NextPageCommand}"/>
                    </StackPanel>
                    <DataGrid ItemsSource="{Binding NodeResults}" SelectedItem="{Binding SelectedNode}"
                              IsReadOnly="True" AutoGenerateColumns="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Address" Binding="{Binding Address}" Width="120"/>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="160"/>
                            <DataGridTextColumn Header="Location" Binding="{Binding Location}" Width="160"/>
                            <DataGridTextColumn Header="Sysop" Binding="{Binding Sysop}" Width="140"/>
                            <DataGridTextColumn Header="Phone" Binding="{Binding Phone}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <TabItem Header="NetMail">
                <StackPanel Spacing="6" MaxWidth="520" Margin="8">
                    <TextBox Text="{Binding ToAddr}" PlaceholderText="To address (1:234/56)"/>
                    <TextBox Text="{Binding ToName}" PlaceholderText="To name"/>
                    <TextBox Text="{Binding NmSubject}" PlaceholderText="Subject"/>
                    <TextBox Text="{Binding NmBody}" AcceptsReturn="True" Height="160" TextWrapping="Wrap" PlaceholderText="Body"/>
                    <CheckBox Content="Crash (direct delivery)" IsChecked="{Binding Crash}"/>
                    <Button Content="Send NetMail" Command="{Binding SendNetmailCommand}"/>
                </StackPanel>
            </TabItem>
        </TabControl>

        <TextBlock DockPanel.Dock="Bottom" Text="{Binding Status}" Opacity="0.8" TextWrapping="Wrap" Margin="0,8,0,0"/>
    </DockPanel>
</UserControl>
