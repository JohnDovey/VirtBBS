<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VirtBBS.GUI.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="550"
             x:Class="VirtBBS.GUI.Views.CallersView"
             x:DataType="vm:CallersViewModel">

    <DockPanel Margin="10">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="6" Margin="0,0,0,8">
            <Button Content="Refresh" Command="{Binding LoadCommand}"/>
            <TextBox Text="{Binding SearchQuery}" Width="220" PlaceholderText="Search caller name..."/>
            <Button Content="Search" Command="{Binding SearchCommand}"/>
            <TextBlock Text="{Binding StatsText}" VerticalAlignment="Center" Margin="12,0,0,0"/>
        </StackPanel>

        <TextBlock DockPanel.Dock="Bottom" Text="{Binding Status}" Margin="0,8,0,0" Opacity="0.8"/>

        <DataGrid ItemsSource="{Binding Callers}" IsReadOnly="True"
                  GridLinesVisibility="Horizontal" AutoGenerateColumns="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="When"     Binding="{Binding Timestamp}"    Width="160"/>
                <DataGridTextColumn Header="Name"     Binding="{Binding UserName}"     Width="150"/>
                <DataGridTextColumn Header="City"     Binding="{Binding City}"         Width="140"/>
                <DataGridTextColumn Header="Remote"   Binding="{Binding RemoteAddr}"   Width="130"/>
                <DataGridTextColumn Header="Sec"      Binding="{Binding SecurityLevel}" Width="50"/>
                <DataGridTextColumn Header="Node"     Binding="{Binding Node}"         Width="50"/>
                <DataGridTextColumn Header="Action"   Binding="{Binding Action}"       Width="90"/>
                <DataGridTextColumn Header="Duration" Binding="{Binding DurationSecs}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>

</UserControl>
