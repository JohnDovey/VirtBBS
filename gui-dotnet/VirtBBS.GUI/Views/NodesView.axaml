<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VirtBBS.GUI.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="500"
             x:Class="VirtBBS.GUI.Views.NodesView"
             x:DataType="vm:NodesViewModel">

    <DockPanel Margin="10">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="6" Margin="0,0,0,8">
            <Button Content="Refresh" Command="{Binding LoadCommand}"/>
            <Button Content="Kick Selected" Command="{Binding KickCommand}"/>
            <TextBox Text="{Binding BroadcastMessage}" Width="300" PlaceholderText="Broadcast message..."/>
            <Button Content="Broadcast" Command="{Binding BroadcastCommand}"/>
        </StackPanel>

        <TextBlock DockPanel.Dock="Bottom" Text="{Binding Status}" Margin="0,8,0,0" Opacity="0.8"/>

        <DataGrid ItemsSource="{Binding Nodes}" SelectedItem="{Binding SelectedNode}"
                  IsReadOnly="True" GridLinesVisibility="Horizontal" AutoGenerateColumns="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Node"   Binding="{Binding NodeID}"      Width="60"/>
                <DataGridTextColumn Header="User"   Binding="{Binding UserName}"    Width="160"/>
                <DataGridTextColumn Header="City"   Binding="{Binding City}"        Width="160"/>
                <DataGridTextColumn Header="Status" Binding="{Binding Status}"      Width="120"/>
                <DataGridTextColumn Header="Action" Binding="{Binding Action}"      Width="160"/>
                <DataGridTextColumn Header="Since"  Binding="{Binding ConnectedAt}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>

</UserControl>
