<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VirtBBS.GUI.ViewModels"
             x:Class="VirtBBS.GUI.Views.FidoHubView"
             x:DataType="vm:FidoHubViewModel">

    <TabControl Margin="8">
        <TabItem Header="Networks">
            <ContentControl Content="{Binding Networks}"/>
        </TabItem>
        <TabItem Header="Routing">
            <ContentControl Content="{Binding Routing}"/>
        </TabItem>
        <TabItem Header="Operations">
            <ContentControl Content="{Binding Operations}"/>
        </TabItem>
    </TabControl>
</UserControl>
