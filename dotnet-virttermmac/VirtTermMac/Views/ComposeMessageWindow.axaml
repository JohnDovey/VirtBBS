<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="VirtTermMac.Views.ComposeMessageWindow"
        Title="Compose"
        Width="480" Height="420"
        CanResize="false"
        WindowStartupLocation="CenterOwner">

    <DockPanel Margin="12">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,12,0,0">
            <Button Name="CancelButton" Content="Cancel"/>
            <Button Name="QueueButton" Content="Queue" IsDefault="True"/>
        </StackPanel>

        <StackPanel Spacing="8">
            <TextBlock Name="TitleText" FontWeight="Bold"/>
            <TextBox Name="ToBox" PlaceholderText="To"/>
            <TextBox Name="FromBox" PlaceholderText="From"/>
            <TextBox Name="SubjectBox" PlaceholderText="Subject"/>
            <TextBox Name="BodyBox" PlaceholderText="Message body" AcceptsReturn="True"
                     TextWrapping="Wrap" MinHeight="180"/>
        </StackPanel>
    </DockPanel>
</Window>
