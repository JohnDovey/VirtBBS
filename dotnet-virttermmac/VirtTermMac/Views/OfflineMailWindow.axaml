<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="VirtTermMac.Views.OfflineMailWindow"
        Title="Offline Mail (QWK)"
        Width="960" Height="640"
        WindowStartupLocation="CenterScreen">

    <DockPanel>
        <Menu DockPanel.Dock="Top" Name="MainMenu">
            <MenuItem Header="_File">
                <MenuItem Header="_Open QWK Packet..." Name="OpenQwkItem"/>
                <MenuItem Header="Save _REP Packet..." Name="SaveRepItem"/>
                <Separator/>
                <MenuItem Header="_Download QWK from BBS..." Name="DownloadBbsItem"/>
                <MenuItem Header="_Upload REP to BBS..." Name="UploadBbsItem"/>
                <Separator/>
                <MenuItem Header="E_xit" Name="CloseItem"/>
            </MenuItem>
            <MenuItem Header="_Message">
                <MenuItem Header="_New Message..." Name="NewMessageItem"/>
                <MenuItem Header="_Reply..." Name="ReplyItem"/>
            </MenuItem>
            <MenuItem Header="_Queue">
                <MenuItem Header="_View Pending Replies..." Name="ViewQueueItem"/>
            </MenuItem>
        </Menu>

        <Border DockPanel.Dock="Bottom" Padding="6,4" Background="#1e1e1e">
            <TextBlock Name="StatusText" Foreground="#cccccc"/>
        </Border>

        <Grid ColumnDefinitions="220,4,*,4,320" Margin="8">
            <DockPanel Grid.Column="0">
                <TextBlock DockPanel.Dock="Top" Text="Conferences" FontWeight="Bold" Margin="0,0,0,6"/>
                <ListBox Name="ConferenceList"/>
            </DockPanel>

            <GridSplitter Grid.Column="1" Width="4" Background="#444"/>

            <DockPanel Grid.Column="2">
                <TextBlock DockPanel.Dock="Top" Name="MessageHeader" Text="Messages" FontWeight="Bold" Margin="0,0,0,6"/>
                <ListBox Name="MessageList"/>
            </DockPanel>

            <GridSplitter Grid.Column="3" Width="4" Background="#444"/>

            <DockPanel Grid.Column="4">
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="6" Margin="0,0,0,6">
                    <Button Name="ReplyButton" Content="Reply"/>
                    <Button Name="NewButton" Content="New"/>
                </StackPanel>
                <ScrollViewer>
                    <StackPanel Name="DetailPanel" Spacing="4">
                        <TextBlock Name="DetailFrom" FontWeight="Bold"/>
                        <TextBlock Name="DetailTo"/>
                        <TextBlock Name="DetailSubject" FontWeight="SemiBold"/>
                        <TextBlock Name="DetailDate" Opacity="0.7"/>
                        <TextBox Name="DetailBody" AcceptsReturn="True" TextWrapping="Wrap"
                                 IsReadOnly="True" MinHeight="200"/>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Grid>
    </DockPanel>
</Window>
