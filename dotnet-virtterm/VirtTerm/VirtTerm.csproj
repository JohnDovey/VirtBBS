<Project Sdk="Microsoft.NET.Sdk">
  <!--
    VirtTerm — graphical VirtBBS terminal client (Phase 3 of the VirtAnd/
    VirtTerm plan). Connects to internal/virtterm's TLS transport for the
    live 80x25 terminal pane, and internal/userapi for the dynamic menu
    and nodelist sync. See README.md in this directory for details.
  -->
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>VirtTerm</AssemblyName>
    <RootNamespace>VirtTerm</RootNamespace>
  </PropertyGroup>
</Project>
