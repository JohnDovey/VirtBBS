# MathMaze configuration (optional — defaults apply if missing)

base_width = 9
base_height = 7

# Where to write the Top Scores bulletin (VirtBBS display folder so callers see it)
bulletin_path = "../../display/MATHMAZE.ANS"

# A starter MATHMAZE.ANS also ships in this directory for the repo.

# How many entries in each Top / Lowest list
top_n = 10
